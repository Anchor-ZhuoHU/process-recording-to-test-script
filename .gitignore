# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# take-home provided materials. Two files directly under resources/ ARE shipped: the assignment
# brief (instruction.pdf, the root of this project) and our verified API writeup
# (instruction-google-api.md, our learning output). Everything else under resources/, including all
# subfolders (demo videos, vendor API docs), stays local-only.
/resources/*
!/resources/instruction.pdf
!/resources/instruction-google-api.md

# throwaway spikes (e.g. live-API model probes) run against .env.local; not shipped.
/scripts/
